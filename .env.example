# ===========================================
# ZeroOps Environment Variables
# Copy to .env and fill in your values
# ===========================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- GitHub OAuth (configured in Supabase dashboard) ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- AWS ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_ACCOUNT_ID=your-aws-account-id
CODEBUILD_PROJECT_NAME=zeroops-builder
ECR_REPOSITORY_PREFIX=zeroops
EC2_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
EC2_PUBLIC_HOST=your-ec2-public-ip-or-dns

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_DOMAIN=zeroops.com

# --- Redis (for BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Backend ---
PORT=4000
FRONTEND_URL=http://localhost:3000
